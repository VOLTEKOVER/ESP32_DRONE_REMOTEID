{
  "name": "rid-hub",
  "version": "1.0.0",
  "description": "RID Hub — Open DroneID Ground Station",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.votekover.rid-hub",
    "productName": "RID Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer/**/*",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "VOLTEKOVER",
      "repo": "ESP_DRONE_REMOTEID"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "serialport": "^13.0.0"
  },
  "optionalDependencies": {
    "@abandonware/noble": "^1.9.2",
    "pcap": "^3.1.0"
  },
  "devDependencies": {
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3"
  }
}
